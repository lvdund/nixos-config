set $mod Mod4
font pango:FiraCode Nerd Font Bold 13
# exec --no-startup-id xrandr --output DP-0 --mode 2560x1440 --rate 99.95
exec --no-startup-id dex --autostart --environment i3
exec_always --no-startup-id feh --bg-scale ~/.config/wallpapers/black.jpg
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id xset s off && xset -dpms && xset s noblank
exec --no-startup-id dunst
exec --no-startup-id xclip
exec --no-startup-id fcitx5
exec_always --no-startup-id bash ~/.config/polybar/launch.sh
# exec_always --no-startup-id picom -b --config ~/.config/picom/picom.conf

# Use pactl to adjust volume and brightness.
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +2% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -2% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

# Use Mouse+$mod
floating_modifier $mod
tiling_drag modifier titlebar
bindsym $mod+Down focus down
bindsym $mod+Up focus up

bindsym $mod+j focus down
bindsym $mod+k focus up

bindsym $mod+h exec bash ~/.config/i3/focus_wrap.sh left prev
bindsym $mod+l exec bash ~/.config/i3/focus_wrap.sh right next
bindsym $mod+Left exec bash ~/.config/i3/focus_wrap.sh left prev
bindsym $mod+Right exec bash ~/.config/i3/focus_wrap.sh right next

# Rofi
bindsym $mod+a exec bash ~/.config/rofi/launchers/launcher.sh 
bindsym $mod+Shift+e exec bash ~/.config/rofi/powermenu/i3-powermenu.sh

# main apps
bindsym $mod+t exec kitty --detach
bindsym $mod+b exec --no-startup-id firefox
bindsym $mod+e exec nautilus
bindsym $mod+Shift+s exec pavucontrol

# kill focused window
bindsym $mod+Shift+q kill

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle
# change container layout (stacked, tabbed, toggle split)
bindsym $mod+d layout tabbed
bindsym $mod+s layout toggle split
bindsym Mod1+Tab focus next
# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# Screen Capture - Note:
bindsym $mod+P exec --no-startup-id maim "/home/$USER/Pictures/$(date)"
bindsym Ctrl+$mod+P exec --no-startup-id maim --select | xclip -selection clipboard -t image/png

# Define names for default workspaces
set $ws1 " 1 "
set $ws2 " 2 "
set $ws3 " 3 "
set $ws4 " 4 "
set $ws5 " 5 "
set $ws6 " 6 "
set $ws7 " 7 "
set $ws8 " 8 "
set $ws9 " 9 "
set $ws10 "10"
# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move to cycle workspace
bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev
bindsym $mod+Shift+Right workspace next
bindsym $mod+Shift+Left workspace prev

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# reload the configuration file
# bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+c restart

# resize window (you can also use the mouse for that)
bindsym $mod+minus resize shrink width 5 px or 5 ppt
bindsym $mod+equal resize grow width 5 px or 5 ppt
bindsym $mod+Shift+minus resize shrink height 5 px or 5 ppt
bindsym $mod+Shift+equal resize grow height 5 px or 5 ppt

#bindsym $mod+Shift+r mode "resize"
mode "resize" {
        bindsym j resize shrink width 5 px or 5 ppt
        bindsym k resize grow height 5 px or 5 ppt
        bindsym l resize shrink height 5 px or 5 ppt
        bindsym semicolon resize grow width 5 px or 5 ppt

        bindsym Left resize shrink width 5 px or 5 ppt
        bindsym Down resize grow height 5 px or 5 ppt
        bindsym Up resize shrink height 5 px or 5 ppt
        bindsym Right resize grow width 5 px or 5 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}


