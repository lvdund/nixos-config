### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
font pango:FiraCode Nerd Font Bold 13

exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

### Output configuration
# Wallpaper
output * bg ~/.config/wallpapers/anya.jpg fill

### Autostart
exec nm-applet --indicator
exec mako
exec fcitx5 -d

### Idle configuration
