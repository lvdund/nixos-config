set $mod Mod4
font pango:FiraCode Nerd Font Bold 13

input type:keyboard {
    xkb_layout us
}

exec --no-startup-id dex --autostart --environment sway
exec_always --no-startup-id bash ~/.config/sway/apply-outputs.sh
exec_always --no-startup-id swaybg -i ~/.config/wallpapers/black.jpg -m fill
exec --no-startup-id nm-applet --indicator
exec --no-startup-id systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP SWAYSOCK
exec --no-startup-id mako
exec --no-startup-id fcitx5
exec_always --no-startup-id bash ~/.config/waybar/launch.sh
# exec --no-startup-id swayidle -w \
#     timeout 600 'swaylock -f -c 111111' \
#     timeout 900 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
#     before-sleep 'swaylock -f -c 111111'

floating_modifier $mod
default_border pixel 3

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +2%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -2%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+h exec bash ~/.config/sway/focus_wrap.sh left prev
bindsym $mod+l exec bash ~/.config/sway/focus_wrap.sh right next
bindsym $mod+Left exec bash ~/.config/sway/focus_wrap.sh left prev
bindsym $mod+Right exec bash ~/.config/sway/focus_wrap.sh right next

bindsym $mod+a exec bash ~/.config/rofi/launchers/launcher.sh
bindsym $mod+Shift+e exec bash ~/.config/rofi/powermenu/powermenu.sh

bindsym $mod+t exec kitty --detach
bindsym $mod+b exec --no-startup-id firefox
bindsym $mod+Shift+b exec --no-startup-id firefox --private-window
bindsym $mod+e exec nautilus
bindsym $mod+Shift+s exec pavucontrol

bindsym $mod+Shift+q kill
bindsym $mod+f fullscreen toggle
bindsym $mod+d layout tabbed
bindsym $mod+s layout toggle split
bindsym Mod1+Tab focus next
bindsym $mod+Shift+space floating toggle

bindsym $mod+P exec --no-startup-id grim "$HOME/Pictures/$(date +%Y-%m-%d_%H-%M-%S).png"
bindsym Ctrl+$mod+P exec --no-startup-id grim -g "$(slurp)" - | wl-copy

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev
bindsym $mod+Shift+Right workspace next
bindsym $mod+Shift+Left workspace prev

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+c exec swaymsg reload

bindsym $mod+minus resize shrink width 5 px or 5 ppt
bindsym $mod+equal resize grow width 5 px or 5 ppt
bindsym $mod+Shift+minus resize shrink height 5 px or 5 ppt
bindsym $mod+Shift+equal resize grow height 5 px or 5 ppt

mode "resize" {
    bindsym j resize shrink width 5 px or 5 ppt
    bindsym k resize grow height 5 px or 5 ppt
    bindsym l resize shrink height 5 px or 5 ppt
    bindsym semicolon resize grow width 5 px or 5 ppt

    bindsym Left resize shrink width 5 px or 5 ppt
    bindsym Down resize grow height 5 px or 5 ppt
    bindsym Up resize shrink height 5 px or 5 ppt
    bindsym Right resize grow width 5 px or 5 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

client.focused #d12f2c #263640 #93a1a1 #FAAFBE #FAAFBE
client.focused_inactive #263640 #b08500 #93a1a1 #263640 #263640
client.unfocused #263640 #b08500 #93a1a1 #263640 #263640
client.urgent #263640 #b08500 #93a1a1 #263640 #263640
client.placeholder #263640 #b08500 #93a1a1 #263640 #263640
client.background #263640

for_window [class="gwenview|Eog|Sxiv|feh|spectacle|mpv|vlc|ark|File-roller|Xarchiver"] floating enable
for_window [class="gwenview|Eog|Sxiv|feh|spectacle|mpv|vlc|ark|File-roller|Xarchiver"] focus
for_window [window_role="alert"] floating enable

gaps inner 10
smart_gaps off
hide_edge_borders none
